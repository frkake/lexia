# Lexia LLM ‚Äî environment template. Copy to `.env` and fill in real keys.
# `.env` / `.env.local` are git-ignored. `.env.local` overrides `.env`.

# --- Provider selection ---
# Which LLM provider to use: "openai" (default) or "claude".
LLM_PROVIDER=openai

# --- OpenAI (default provider) ---
OPENAI_API_KEY=sk-...
# Optional. Default: gpt-4o
OPENAI_MODEL=gpt-4o

# --- Anthropic / Claude (switchable) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional. Default: claude-opus-4-8
ANTHROPIC_MODEL=claude-opus-4-8

# --- Generation defaults (optional) ---
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.7

# --- Character illustration (Requirement 6.7) ---
# Image generation is a SEPARATE axis from text (Anthropic has no image API).
# Which image provider to use: "openai" (default, reuses OPENAI_API_KEY) or "gemini".
IMAGE_PROVIDER=openai
# Optional. Default: gpt-image-1 (openai) / imagen-3.0-generate-002 (gemini).
# IMAGE_MODEL=gpt-image-1
# Required only when IMAGE_PROVIDER=gemini.
# GEMINI_API_KEY=...
