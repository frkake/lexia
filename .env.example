# Lexia LLM ‚Äî environment template. Copy to `.env` and fill in real keys.
# `.env` / `.env.local` are git-ignored. `.env.local` overrides `.env`.

# --- Provider selection ---
# Which LLM provider to use: "openai" (default) or "claude".
LLM_PROVIDER=openai

# --- OpenAI (default provider) ---
OPENAI_API_KEY=sk-...
# Optional. Default: gpt-4o
OPENAI_MODEL=gpt-4o

# --- Anthropic / Claude (switchable) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional. Default: claude-opus-4-8
ANTHROPIC_MODEL=claude-opus-4-8

# --- Generation defaults (optional) ---
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.7
