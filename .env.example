# Lexia LLM — environment template. Copy to `.env` and fill in real keys.
# `.env` / `.env.local` are git-ignored. `.env.local` overrides `.env`.

# --- Provider selection ---
# Which LLM provider to use: "openai" (default) or "claude".
LLM_PROVIDER=openai

# --- OpenAI (default provider) ---
OPENAI_API_KEY=sk-...
# Optional. Default: gpt-4o. New model series (gpt-5*, o-series) are supported — the proxy sends
# `max_completion_tokens` and omits `temperature` for reasoning models automatically.
OPENAI_MODEL=gpt-4o

# --- Anthropic / Claude (switchable) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional. Default: claude-opus-4-8
ANTHROPIC_MODEL=claude-opus-4-8

# --- Per-task model overrides (optional) ---
# Point individual generation tasks at a different model than the provider default above. Unset ⇒
# falls back to OPENAI_MODEL / ANTHROPIC_MODEL. Temperature is fixed per task (passage 0.8, story
# 0.7, word data 0.4, annotation 0.3) and needs no env.
# LLM_MODEL_PASSAGE=
# LLM_MODEL_ANNOTATION=
# LLM_MODEL_WORDPACK=

# --- Image illustration (Requirement 6.7/6.8) ---
# Image generation is a SEPARATE axis from text (Anthropic has no image API).
# Providers: "openai" (default, reuses OPENAI_API_KEY, PNG), "grok"/"xai" (xAI, JPEG, no size/quality
# params), "gemini"/"google"/"imagen" (Imagen). A typo'd value is NOT silently coerced to openai — it
# warns at startup and image requests return 503.
IMAGE_PROVIDER=openai
# Optional. Default: gpt-image-1 (openai) / grok-2-image (grok) / imagen-3.0-generate-002 (gemini).
# IMAGE_MODEL=gpt-image-1

# Provider keys (set the one(s) for the provider(s) you use):
# OPENAI_API_KEY is shared with the text axis above.
# XAI_API_KEY=...          # or GROK_API_KEY — required when a profile resolves to grok/xai.
# GEMINI_API_KEY=...        # required when a profile resolves to gemini.

# --- Per-use image profiles (optional) ---
# Two use profiles sit on top of the provider axis so speed and quality can differ by use:
#   fast    = character art rendered while the learner waits at the story confirmation gate
#   quality = article scene art / one-off assets read slowly (OpenAI is asked for `quality: high`)
# Each profile falls back to IMAGE_PROVIDER / IMAGE_MODEL above, then the provider default. Unset ⇒
# character art = fast, scene art = quality (applied by the illustrate endpoints). Example: fast Grok
# character art + crisp OpenAI scene art —
# IMAGE_PROVIDER_FAST=grok
# IMAGE_MODEL_FAST=grok-2-image
# IMAGE_PROVIDER_QUALITY=openai
# IMAGE_MODEL_QUALITY=gpt-image-1

# --- Text-to-speech / listening audio ---
# Azure Speech is the preferred provider for accent-rich listening scenes.
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_REGION=eastus

# Amazon Polly is supported as a compatible fallback for single-voice narration.
# AWS_REGION=us-east-1
# POLLY_ENGINE=neural

# OpenAI TTS voices reuse OPENAI_API_KEY from the text axis above, so an LLM-only .env still
# enables narration (with the OpenAI voices). OpenAI returns no word-level speech marks;
# highlight timing is estimated client-side (approximate follow-along).
# NOTE: there is NO cross-provider fallback — each voice synthesizes only on its own provider.
# Voices whose provider is not configured here are reported as 生成不可 in the app instead of
# being silently swapped for another engine's voice.
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
