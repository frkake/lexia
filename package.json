{
  "name": "lexia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Lexia — context-based English vocabulary learning SPA",
  "scripts": {
    "dev": "NODE_USE_ENV_PROXY=1 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "NODE_USE_ENV_PROXY=1 vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@aws-sdk/client-polly": "^3.1078.0",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource-variable/noto-serif-jp": "^5.2.9",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tanstack/react-query": "^5.101.2",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
